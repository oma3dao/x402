{
  "name": "x402_monorepo",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.1.1"
  },
  "packageManager": "pnpm@11.1.1",
  "private": "true",
  "version": "0.0.2",
  "description": "x402 Payment Protocol Monorepo",
  "main": "index.js",
  "scripts": {
    "build": "turbo run build",
    "build:paywall-deps": "turbo run build --filter='@x402/paywall^...'",
